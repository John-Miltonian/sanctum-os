#!/bin/bash
# sanctum-help - Display Sanctum OS help

RED="\033[38;5;88m"
GOLD="\033[38;5;178m"
SILVER="\033[38;5;250m"
BLACK="\033[38;5;232m"
RESET="\033[0m"

cat << EOF
${RED}
    ╔═══════════════════════════════════════════════════════════════════╗
