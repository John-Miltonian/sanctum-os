#!/bin/bash
# sanctum-term - Terminal Scripture Widget
# Displays Bible verses in a terminal panel

# ═══════════════════════════════════════════════════════════════════════════════
# CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

WIDTH=${1:-80}
MODE=${2:-daily}  # daily, random, or reference

# Colors
RED="\033[38;5;88m"
GOLD="\033[38;5;178m"
SILVER="\033[38;5;250m"
DIM="\033[38;5;240m"
RESET="\033[0m"

# ═══════════════════════════════════════════════════════════════════════════════
# DRAW BORDER
# ═══════════════════════════════════════════════════════════════════════════════

draw_border() {
    local width=$1
    local char=${2:-─}
    local line=""
    for ((i=0; i<width; i++)); do
        line+="$char"
    done
    echo -e "$line"
}

# ═══════════════════════════════════════════════════════════════════════════════
# GET VERSE
# ═══════════════════════════════════════════════════════════════════════════════

get_verse() {
    local mode=$1
    
    if command -v biblia &> /dev/null; then
        case $mode in
            random)
                biblia --random --compact 2>/dev/null || echo "John 3:16 | For God so loved the world..."
                ;;
            reference)
                shift
                biblia "$@" --compact 2>/dev/null || echo "Psalm 119:105 | Your word is a lamp to my feet..."
                ;;
            daily|*)
                # Get verse of the day based on date
                local day_of_year=$(date +%j)
                local verses=(
                    "John 3:16 | For God so loved the world that He gave His only begotten Son..."
                    "Psalm 23:1 | The LORD is my shepherd; I shall not want."
                    "Romans 8:28 | And we know that all things work together for good..."
                    "Philippians 4:13 | I can do all things through Christ who strengthens me."
                    "Jeremiah 29:11 | For I know the plans I have for you, declares the LORD..."
                    "Matthew 11:28 | Come to Me, all you who labor and are heavy laden..."
                    "Isaiah 41:10 | Fear not, for I am with you; be not dismayed..."
                    "Proverbs 3:5 | Trust in the LORD with all your heart..."
                    "Psalm 46:10 | Be still, and know that I am God..."
                    "Joshua 1:9 | Have I not commanded you? Be strong and courageous..."
                    "Hebrews 11:1 | Now faith is the substance of things hoped for..."
                    "2 Timothy 1:7 | For God has not given us a spirit of fear..."
                    "1 Corinthians 16:14 | Let all that you do be done with love."
                    "Galatians 5:22 | But the fruit of the Spirit is love, joy, peace..."
                    "Ephesians 2:8 | For by grace you have been saved through faith..."
                    "James 1:5 | If any of you lacks wisdom, let him ask of God..."
                    "1 Peter 5:7 | Casting all your care upon Him, for He cares for you."
                    "Colossians 3:23 | And whatever you do, do it heartily, as to the Lord..."
                    "Romans 5:8 | But God demonstrates His own love toward us..."
                    "John 14:27 | Peace I leave with you, My peace I give to you..."
                    "Psalm 119:11 | Your word I have hidden in my heart..."
                    "Isaiah 40:31 | But those who wait on the LORD shall renew their strength..."
                    "Matthew 6:33 | But seek first the kingdom of God and His righteousness..."
                    "2 Corinthians 5:17 | Therefore, if anyone is in Christ, he is a new creation..."
                    "John 1:1 | In the beginning was the Word, and the Word was with God..."
                    "Psalm 27:1 | The LORD is my light and my salvation; whom shall I fear?"
                    "Romans 12:2 | And do not be conformed to this world..."
                    "1 John 4:7 | Beloved, let us love one another, for love is of God..."
                    "Psalm 91:1 | He who dwells in the secret place of the Most High..."
                    "Matthew 5:16 | Let your light so shine before men..."
                    "Luke 6:31 | And just as you want men to do to you..."
                    "Proverbs 18:10 | The name of the LORD is a strong tower..."
                    "Isaiah 53:5 | But He was wounded for our transgressions..."
                    "Revelation 3:20 | Behold, I stand at the door and knock..."
                    "Romans 15:13 | Now may the God of hope fill you with all joy..."
                    "1 Thessalonians 5:16-18 | Rejoice always, pray without ceasing..."
                )
                local index=$(( (day_of_year - 1) % ${#verses[@]} ))
                echo "${verses[$index]}"
                ;;
        esac
    else
        # Fallback to embedded verses
        echo "John 3:16 | For God so loved the world that He gave His only begotten Son..."
    fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# DISPLAY
# ═══════════════════════════════════════════════════════════════════════════════

# Clear screen (optional)
[[ "$CLEAR" == "1" ]] && clear

# Header
echo -e "${RED}"
draw_border $WIDTH "═"
echo -e "${RESET}${GOLD}  ✝  SANCTUM TERMINAL • VERSE OF THE DAY${RESET}"
echo -e "${RED}"
draw_border $WIDTH "─"
echo -e "${RESET}"

# Get and display verse
verse_text=$(get_verse "$MODE" "$@")
reference=$(echo "$verse_text" | cut -d'|' -f1 | xargs)
text=$(echo "$verse_text" | cut -d'|' -f2- | xargs)

# Display
echo -e "${SILVER}"
# Word wrap the text
local wrapped=""
local line="  "
for word in $text; do
    if (( ${#line} + ${#word} + 1 > WIDTH - 4 )); then
        echo "$line"
        line="  $word"
    else
        line="$line $word"
    fi
done
echo "$line"

echo -e "${RESET}"
echo -e "${DIM}  — $reference${RESET}"

# Footer
echo -e "${RED}"
draw_border $WIDTH "─"
echo -e "${RESET}${DIM}  Run 'biblia $reference' for full context${RESET}"
echo -e "${RED}"
draw_border $WIDTH "═"
echo -e "${RESET}"
